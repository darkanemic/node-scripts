#!/bin/sh
# OpenWrt / BusyBox compatible
# Ensures SSH public key exists in dropbear authorized_keys
set -eu

# === ВСТАВЬ СВОЙ ПУБЛИЧНЫЙ КЛЮЧ ЗДЕСЬ (ОДНОЙ СТРОКОЙ) ===
SSH_KEY='ssh-rsa  dark'

# Где хранит ключи dropbear на OpenWrt
DB_DIR="/etc/dropbear"
AUTH_KEYS="$DB_DIR/authorized_keys"

# Параметры:
#   --disable-password   отключить вход по паролю (uci) после добавления ключа
#   --no-restart         не перезапускать dropbear
DISABLE_PASSWORD=0
RESTART=1

for arg in "$@"; do
  case "$arg" in
    --disable-password) DISABLE_PASSWORD=1 ;;
    --no-restart) RESTART=0 ;;
    *) echo "Unknown arg: $arg" >&2; exit 2 ;;
  esac
done

# sanity checks
if [ -z "${SSH_KEY:-}" ]; then
  echo "ERROR: SSH_KEY is empty" >&2
  exit 1
fi

# Создаём каталог/файл (надёжно для BusyBox ash, даже при запуске через pipe | sh)
umask 077
mkdir -p "$DB_DIR"

if [ ! -f "$AUTH_KEYS" ]; then
  touch "$AUTH_KEYS"
fi

if [ ! -f "$AUTH_KEYS" ]; then
  echo "ERROR: cannot create $AUTH_KEYS" >&2
  exit 1
fi

# Права (важно для dropbear)
chmod 700 "$DB_DIR"
chmod 600 "$AUTH_KEYS"

# Убедимся, что в конце файла есть перевод строки, иначе ключ может слиться с предыдущей строкой
if [ -s "$AUTH_KEYS" ]; then
  lastchar="$(tail -c 1 "$AUTH_KEYS" 2>/dev/null || true)"
  if [ "$lastchar" != "" ] && [ "$lastchar" != "$(printf '\n')" ]; then
    printf '\n' >> "$AUTH_KEYS"
  fi
fi

# Проверяем, есть ли уже такой ключ (точное совпадение строки)
if grep -F -x -q "$SSH_KEY" "$AUTH_KEYS" 2>/dev/null; then
  :
else
  FOUND=0
  while IFS= read -r line; do
    [ "$line" = "$SSH_KEY" ] && FOUND=1 && break
  done < "$AUTH_KEYS" || true

  if [ "$FOUND" -eq 0 ]; then
    printf '%s\n' "$SSH_KEY" >> "$AUTH_KEYS"
  fi
fi

# Опционально отключаем пароль
if [ "$DISABLE_PASSWORD" -eq 1 ]; then
  uci set dropbear.@dropbear[0].PasswordAuth='off' 2>/dev/null || true
  uci set dropbear.@dropbear[0].RootPasswordAuth='off' 2>/dev/null || true
  uci commit dropbear 2>/dev/null || true
fi

# Перезапуск dropbear
if [ "$RESTART" -eq 1 ]; then
  /etc/init.d/dropbear restart >/dev/null 2>&1 || true
fi

# Финальная проверка и вывод содержимого
echo "OK: key ensured in $AUTH_KEYS (dropbear)."
if [ "$DISABLE_PASSWORD" -eq 1 ]; then
  echo "OK: password auth disabled (dropbear uci)."
else
  echo "NOTE: password auth unchanged (use --disable-password to turn it off)."
fi

if [ -f "$AUTH_KEYS" ]; then
  echo
  echo "=== $AUTH_KEYS (contents) ==="
  # Покажем с номерами строк, чтобы было видно переносы/дубли
  nl -ba "$AUTH_KEYS" 2>/dev/null || cat "$AUTH_KEYS"
else
  echo "ERROR: $AUTH_KEYS is missing after script run" >&2
  exit 1
fi
